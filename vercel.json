{
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/partners.js": { "maxDuration": 30 },
    "api/reports.js": { "maxDuration": 30 },
    "api/merchants.js": { "maxDuration": 30 },
    "api/ai-import.js": { "maxDuration": 60 },
    "api/security-check.js": { "maxDuration": 60 },
    "api/cron-security-check.js": { "maxDuration": 60 },
    "api/scheduled-reports.js": { "maxDuration": 60 },
    "api/cron-daily-report.js": { "maxDuration": 60 }
  },
  "crons": [
    {
      "path": "/api/cron-security-check",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron-daily-report",
      "schedule": "0 9 * * *"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/partner/dashboard", "dest": "/partner/dashboard.html" },
    { "src": "/partner/merchants", "dest": "/partner/merchants.html" },
    { "src": "/partner/messages", "dest": "/partner/messages.html" },
    { "src": "/partner/community", "dest": "/partner/community.html" },
    { "src": "/partner/settings", "dest": "/partner/settings.html" },
    { "src": "/partner/profile", "dest": "/partner/profile.html" },
    { "src": "/partner", "dest": "/partner/index.html" },
    { "src": "/partner/", "dest": "/partner/index.html" },
    { "src": "/(.*)\\.html", "dest": "/$1.html" },
    { "src": "/(.*)", "dest": "/$1.html" }
  ]
}
